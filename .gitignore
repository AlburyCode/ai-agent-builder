# ============================================================
# ROOT .gitignore — AI Agent Builder
# Cubre reglas globales; cada subcarpeta tiene su propio .gitignore
# ============================================================

# Dependencies (todos los subproyectos)
**/node_modules/

# Build outputs (todos los subproyectos)
**/dist/

# Environment variables — NUNCA subir credenciales al repo
.env
.env.local
.env.*.local
**/.env
**/.env.local
**/.env.*.local

# Logs
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Test coverage
coverage/
.nyc_output/

# TypeScript incremental cache
*.tsbuildinfo

# Angular cache
**/.angular/cache/

# Vite cache
**/.vite/

# OS files
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# Editor directories
.idea/
.project
.classpath
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Visual Studio Code
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.history/

# Runtime data
pids/
*.pid
*.seed
*.pid.lock
