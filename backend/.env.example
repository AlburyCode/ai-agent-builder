# ── Servidor ──────────────────────────────────────────────────
PORT=3000

# ── Base de datos (PostgreSQL) ────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=aiagentbuilder
DB_USER=postgres
DB_PASSWORD=

# ── JWT ───────────────────────────────────────────────────────
# Genera un valor seguro: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=cambia_esto_por_un_secreto_seguro

# ── OpenAI ────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── CORS ─────────────────────────────────────────────────────
# En producción, pon la URL de tu frontend en Vercel.
# Para múltiples orígenes separa con comas: https://app.vercel.app,https://custom-domain.com
FRONTEND_URL=http://localhost:4200
